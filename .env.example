# TrueView local server
PORT=5173

# Optional: override the local Mac report export folder.
# Leave blank to use ~/Desktop/TrueView Reports.
TRUEVIEW_EXPORT_ROOT=

# Optional Supabase cloud sync public config.
# Do not put real production secrets in this file.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-public-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
NEXT_PUBLIC_TRUEVIEW_SYNC_SPACE_ID=replace-with-a-long-random-sync-space-id
